rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Products collection - publicly readable and writable (including sub-collections)
    match /products/{document=**} {
      allow read, write: if true;
    }
    
    // Settings collection - publicly readable and writable (including sub-collections)
    match /settings/{document=**} {
      allow read, write: if true;
    }
  }
}
