{
  "entities": {
    "Product": {
      "title": "Product",
      "description": "A product for sale in the shop",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique product ID" },
        "name": { "type": "string", "description": "Product name" },
        "price": { "type": "string", "description": "Product price" },
        "imageUrl": { "type": "string", "description": "URL of the product image" },
        "category": { "type": "string", "description": "Product category (Coins, Dinheiro, Contas)" }
      },
      "required": ["name", "price", "category"]
    }
  },
  "firestore": {
    "/products/{productId}": {
      "schema": "Product",
      "description": "Collection of products"
    }
  }
}
